# Copy this file to .env and fill in real values.
# .env itself is gitignored and must never be committed.

# Django secret key — generate your own, never reuse this placeholder.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key

# True locally, False in production.
DEBUG=True

# Comma-separated list of allowed hostnames.
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset locally to fall back to SQLite (see settings.py).
# In production (or when using docker-compose), set to your Postgres URL, e.g.:
# DATABASE_URL=postgres://flashcraft:flashcraft@db:5432/flashcraft
